/ {
	chosen {
		nordic,pm-ext-flash = &mx25r64;
	};

	input {
		compatible = "gpio-keys";
		sensor: sensor_0 {
			gpios = <&gpio1 15 (GPIO_PULL_UP | GPIO_ACTIVE_HIGH)>;
			label = "Interrupt PIN";
			zephyr,code = <INPUT_KEY_0>;
		};
	};
};

&adc {
	status = "disabled";
};
&uart1 {
	status = "disabled";
};
&i2c0 {
	status = "disabled";
};
&pwm0 {
	status = "disabled";
};
&spi1 {
	status = "disabled";
};
&spi3 {
	status = "disabled";
};
&usbd {
	status = "disabled";
};
